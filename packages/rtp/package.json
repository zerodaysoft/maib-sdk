{
  "name": "@maib/rtp",
  "version": "0.2.2",
  "license": "MIT",
  "author": {
    "name": "Zero-day",
    "url": "https://www.zero-day.md",
    "email": "contact@zero-day.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerodaysoft/maib-sdk.git",
    "directory": "packages/rtp"
  },
  "homepage": "https://github.com/zerodaysoft/maib-sdk",
  "bugs": {
    "url": "https://github.com/zerodaysoft/maib-sdk/issues"
  },
  "keywords": [
    "maib",
    "moldova",
    "payments",
    "rtp",
    "request-to-pay",
    "sdk"
  ],
  "description": "TypeScript SDK for the maib Request to Pay (RTP) API — bank-initiated payment requests",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@maib/core": "workspace:*"
  }
}

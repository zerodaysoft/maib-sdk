{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["@maib/core#build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["@maib/core#build"]
    },
    "test": {
      "dependsOn": ["@maib/core#build"]
    },
    "lint": {
      "dependsOn": ["@maib/core#build"]
    },
    "lint:fix": {
      "dependsOn": ["@maib/core#build"]
    }
  }
}

{
  "name": "@maib/internal-schemas",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace-internal source for Zod schemas shared across @maib/* packages. Not published.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schemas-builder": {
      "import": {
        "types": "./dist/schemas-builder.d.ts",
        "default": "./dist/schemas-builder.js"
      },
      "require": {
        "types": "./dist/schemas-builder.d.cts",
        "default": "./dist/schemas-builder.cjs"
      }
    },
    "./test-helpers": {
      "import": {
        "types": "./dist/test-helpers.d.ts",
        "default": "./dist/test-helpers.js"
      },
      "require": {
        "types": "./dist/test-helpers.d.cts",
        "default": "./dist/test-helpers.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit"
  }
}

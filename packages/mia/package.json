{
  "name": "@maib/mia",
  "version": "0.3.2",
  "license": "MIT",
  "author": {
    "name": "Zero-day",
    "url": "https://www.zero-day.md",
    "email": "contact@zero-day.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerodaysoft/maib-sdk.git",
    "directory": "packages/mia"
  },
  "homepage": "https://github.com/zerodaysoft/maib-sdk",
  "bugs": {
    "url": "https://github.com/zerodaysoft/maib-sdk/issues"
  },
  "keywords": [
    "maib",
    "moldova",
    "payments",
    "mia",
    "qr",
    "sdk"
  ],
  "description": "TypeScript SDK for the maib MIA QR payment API — static, dynamic, and hybrid QR code payments",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas-builder.d.ts",
        "default": "./dist/schemas-builder.js"
      },
      "require": {
        "types": "./dist/schemas-builder.d.cts",
        "default": "./dist/schemas-builder.cjs"
      }
    },
    "./schemas/bundle.json": "./dist/schemas/bundle.json",
    "./schemas/*.json": "./dist/schemas/*.json",
    "./schemas/*": {
      "import": {
        "types": "./dist/schemas/*.d.ts",
        "default": "./dist/schemas/*.js"
      },
      "require": {
        "types": "./dist/schemas/*.d.cts",
        "default": "./dist/schemas/*.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/build-schemas.mjs --pre && tsup && node ../../scripts/build-schemas.mjs --post && node ../../scripts/copy-docs.mjs",
    "dev": "node ../../scripts/build-schemas.mjs --pre && tsup --watch",
    "test": "vitest run",
    "lint": "biome check src __tests__",
    "lint:fix": "biome check --write src __tests__",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@maib/core": "workspace:*"
  },
  "devDependencies": {
    "@maib/internal-schemas": "workspace:*"
  }
}

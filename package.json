{
  "name": "maib-sdk",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "Zero-day",
    "url": "https://www.zero-day.md",
    "email": "contact@zero-day.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerodaysoft/maib-sdk.git"
  },
  "homepage": "https://github.com/zerodaysoft/maib-sdk",
  "bugs": {
    "url": "https://github.com/zerodaysoft/maib-sdk/issues"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "biome format --write packages/ && prettier --write \"**/*.md\"",
    "typecheck": "turbo run typecheck"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "endOfLine": "lf",
    "proseWrap": "always"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.4",
    "fast-xml-parser": "^5.8.0",
    "jiti": "^2.7.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "3.8.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "zod": "^4.4.3"
  }
}
